{
  "name": "@sinlair/reagent-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw plugin for ReAgent research workflows",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm --prefix ../reagent-core run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm --prefix ../reagent-core run build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sinlair/reagent-core": "file:../reagent-core",
    "openclaw": "2026.3.23",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@sinlair/reagent-openclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    }
  }
}
